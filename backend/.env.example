# Server configuration
PORT=3000

# Database file path (absolute path or relative to project root)
DATABASE_URL=./chat.db

# LLM Selection (openai | anthropic | mock)
# Defaults to openai if keys are available, otherwise falls back to mock
LLM_PROVIDER=openai

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
